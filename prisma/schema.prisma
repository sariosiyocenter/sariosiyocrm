// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id         Int       @id @default(autoincrement())
  name       String
  phone      String
  birthDate  String
  address    String
  location   String?
  status     String    @default("Faol")
  joinedDate String
  balance    Float     @default(0)
  photo      String?
  rating     Float?
  telegramId String?   @unique
  fatherName  String?
  fatherPhone String?
  motherName  String?
  motherPhone String?

  // Privilege fields
  privilegeType String    @default("None")
  certCategory  String?
  certSubject   String?
  certType      String?
  certScore     String?
  customPrices  Json?     @default("{}")
  certificates  Json?     @default("[]")

  gender          String?   @default("Erkak")

  // New fields for reports
  statusChangedAt DateTime? @default(now())
  leaveReason     String?

  // Transport Relation
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])

  // Student's actual school (maktab)
  studentSchool String?
  orgType       String?
  region        String?
  district      String?

  // Relations
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  groups     Group[]   @relation("StudentGroups")
  payments   Payment[]
  attendances Attendance[]
  scores      Score[]
  deliveryLogs DeliveryLog[]
  examResults ExamResult[]

  @@index([schoolId])
}

model Transport {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Avtobus #1"
  model       String?  // e.g., "Mercedes Sprinter"
  number      String?  // Plate number
  capacity    Int
  driverName  String?
  driverPhone String?
  status      String   @default("Faol") // Faol, Ta'mirda, Arxiv
  
  driverId    Int?     @unique
  driver      User?    @relation("DriverTransport", fields: [driverId], references: [id])
  
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  students    Student[]
  deliveryLogs DeliveryLog[]
  routes      Route[]

  @@index([schoolId])
}

model DeliveryLog {
  id          Int      @id @default(autoincrement())
  transportId Int
  transport   Transport @relation(fields: [transportId], references: [id])
  studentId   Int
  student     Student   @relation(fields: [studentId], references: [id])
  date        String
  status      String    // Olib ketildi, Uyiga yetkazildi, Kelmadi
  
  schoolId    Int
  school      School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  category    String   // Ish haqi, Ijara, Kommunal, Marketing, Boshqa
  date        String
  description String?
  
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Teacher {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  salary          Float
  sharePercentage Float
  lessonFee       Float     @default(0)
  salaryType      String    @default("FIXED") // FIXED, KPI, FIXED_KPI
  birthDate       String
  hiredDate       String
  photo           String?
  status          String    @default("Faol")
  telegramId      String?   @unique

  schoolId        Int
  school          School    @relation(fields: [schoolId], references: [id])
  groups          Group[]
  teacherAttendances TeacherAttendance[]

  @@index([schoolId])
}

model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Group {
  id         Int       @id @default(autoincrement())
  name       String
  teacherId  Int
  teacher    Teacher   @relation(fields: [teacherId], references: [id])
  courseId   Int
  course     Course    @relation(fields: [courseId], references: [id])
  schedule   String
  days       String
  room       Int?
  roomRel    Room?     @relation(fields: [room], references: [id])

  syllabusId Int?
  syllabus   Syllabus? @relation(fields: [syllabusId], references: [id])

  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  students   Student[] @relation("StudentGroups")
  attendances Attendance[]
  scores      Score[]
  examAssignments ExamAssignment[]

  @@index([schoolId])
}

model Lead {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String
  course        String
  source        String
  status        String   @default("Yangi")
  createdAt     DateTime @default(now())

  // Additional profile fields from registration
  birthDate     String?
  address       String?
  studentSchool String?
  orgType       String?
  region        String?
  district      String?
  fatherName    String?
  fatherPhone   String?
  motherName    String?
  motherPhone   String?
  preferredTime String?
  notes         String?
  photo         String?

  // Privilege fields
  privilegeType String    @default("None")
  certCategory  String?
  certSubject   String?
  certType      String?
  certificates  Json?     @default("[]")

  schoolId      Int
  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Float
  type        String
  date        String
  description String

  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Course {
  id         Int       @id @default(autoincrement())
  name       String
  price      Float
  
  syllabusId Int?
  syllabus   Syllabus? @relation(fields: [syllabusId], references: [id])
  
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  groups     Group[]

  @@index([schoolId])
}

model Room {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int

  schoolId Int
  school   School  @relation(fields: [schoolId], references: [id])
  groups   Group[]

  @@index([schoolId])
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  schools   School[]

  status     String    @default("Sinov") // Sinov, Faol, Muzlatilgan
  expiresAt  DateTime?
  maxSchools Int       @default(3)
}

model School {
  id      Int    @id @default(autoincrement())
  name    String
  address String?

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  students Student[]
  teachers Teacher[]
  groups   Group[]
  leads    Lead[]
  payments Payment[]
  courses  Course[]
  rooms    Room[]
  users    User[]
  settings Setting[]
  attendances Attendance[]
  scores      Score[]
  teacherAttendances TeacherAttendance[]
  expenses    Expense[]
  transports  Transport[]
  deliveryLogs DeliveryLog[]
  routes      Route[]
  smsLogs     SmsLog[]
  questions   Question[]
  exams       Exam[]
  examResults ExamResult[]
  examAssignments ExamAssignment[]
  applyTokens      ApplyToken[]
  staffAttendances StaffAttendance[]
  salaryPayments   SalaryPayment[]
  topics           Topic[]
  syllabuses       Syllabus[]
  messageTemplates MessageTemplate[]
  messageCampaigns MessageCampaign[]
  autoMessageRules AutoMessageRule[]
}

model SmsLog {
  id        Int      @id @default(autoincrement())
  toPhone   String
  toName    String?
  message   String
  status    String   @default("PENDING") // SENT, FAILED, PENDING
  type      String   // ATTENDANCE, PAYMENT, PAYMENT_CONFIRM, SCORE, BIRTHDAY
  studentId Int?
  eskizId   String?
  errorMsg  String?
  channel   String   @default("SMS") // SMS | TELEGRAM
  campaignId Int?
  sentAt    DateTime @default(now())

  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  body      String
  category  String   @default("Umumiy") // Qarzdorlik | Tug'ilgan kun | Eslatma | Umumiy
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  @@index([schoolId])
}

model MessageCampaign {
  id          Int      @id @default(autoincrement())
  message     String
  channel     String   // SMS | TELEGRAM | BOTH
  recipientTo String   // PARENT | STUDENT
  filtersJson Json?
  totalCount  Int      @default(0)
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())

  @@index([schoolId])
}

model AutoMessageRule {
  id          Int      @id @default(autoincrement())
  type        String   // BIRTHDAY | DEBT_REMINDER
  enabled     Boolean  @default(false)
  body        String
  channel     String   @default("BOTH")   // SMS | TELEGRAM | BOTH
  recipientTo String   @default("PARENT") // PARENT | STUDENT
  config      Json?
  lastRunDate String?
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, type])
  @@index([schoolId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli

  // Topic tracking
  topicId   Int?
  topic     Topic?   @relation(fields: [topicId], references: [id])
  caughtUp  Boolean  @default(false)
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Topic {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  order       Int      @default(1)
  syllabusId  Int?
  syllabus    Syllabus? @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  attendances Attendance[]

  @@index([schoolId])
  @@index([syllabusId])
}

model Syllabus {
  id          Int      @id @default(autoincrement())
  name        String
  materials   String?  // Uchebniy posobiyalar (text or list of materials)
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  groups      Group[]
  topics      Topic[]
  courses     Course[]

  @@index([schoolId])
}

model Score {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  value     Float
  comment   String?
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Setting {
  id               Int      @id @default(autoincrement())
  schoolId         Int      @unique
  school           School   @relation(fields: [schoolId], references: [id])
  orgName          String   @default("SARIOSIYO")
  logo             String?
  adminPhone       String?
  address          String?
  telegram         String?
  instagram        String?
  workingHours     String?
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  phone     String?
  photo     String?
  position  String?
  salary    Int?     @default(0)
  role      UserRole @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  telegramId String?   @unique

  schoolId  Int?
  school    School?  @relation(fields: [schoolId], references: [id])

  workDays   String?
  kpiPercent Int     @default(0)

  driverTransport  Transport?       @relation("DriverTransport")
  driverRoutes     Route[]          @relation("DriverRoutes")
  sellerLeads      SaaSLead[]       @relation("SellerLeads")
  staffAttendances StaffAttendance[]
  salaryPayments   SalaryPayment[]

  @@index([schoolId])
}

model SalaryPayment {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  month      String   // "2026-06"
  amount     Int
  baseSalary Int
  bonuses    Int      @default(0)
  fines      Int      @default(0)
  note       String?
  paidAt     DateTime @default(now())
  expenseId  Int?
  schoolId   Int
  school     School   @relation(fields: [schoolId], references: [id])

  @@unique([userId, month])
  @@index([schoolId])
  @@index([userId])
}

model StaffAttendance {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id])
  date     String
  status   String
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])

  @@unique([userId, date])
  @@index([schoolId])
  @@index([userId])
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  SUPPORT_TEACHER
  RECEPTIONIST
  DRIVER
  TECH_STAFF
  SELLER
}

model Route {
  id          Int      @id @default(autoincrement())
  name        String
  startTime   String?   // e.g., "08:00"
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])
  driverId    Int?
  driver      User?    @relation("DriverRoutes", fields: [driverId], references: [id])
  days        String   // TOQ, JUFT, HAR_KUNI
  studentIds  Int[]    // Ordered students
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model Question {
  id            Int      @id @default(autoincrement())
  text          String
  imageUrl      String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   // 'A' | 'B' | 'C' | 'D'
  difficulty    Int      @default(1)
  subject       String
  topic         String

  schoolId      Int
  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, subject, topic])
}

model Exam {
  id             Int      @id @default(autoincrement())
  name           String
  date           String
  duration       Int
  status         String   @default("Yaqinlashmoqda")
  blocks         Json     // ExamBlock[] — always read as whole, no per-field queries needed
  totalQuestions Int      @default(0)
  maxScore       Float    @default(0)
  variants       Json?    // Variant[] — generated and stored here
  createdAt      DateTime @default(now())

  schoolId       Int
  school         School   @relation(fields: [schoolId], references: [id])
  results        ExamResult[]
  assignments    ExamAssignment[]

  @@index([schoolId])
}

model ExamAssignment {
  id       Int   @id @default(autoincrement())
  examId   Int
  exam     Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  groupId  Int
  group    Group @relation(fields: [groupId], references: [id])
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])

  @@unique([examId, groupId])
}

model ExamResult {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  examId      Int
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  variantCode String?
  answers     Json?    // Record<number, 'A'|'B'|'C'|'D'|null>
  score       Float    @default(0)
  percentage  Float    @default(0)
  blockScores Json?    // {subject: string, earned: number, max: number}[]
  scannedAt   DateTime @default(now())

  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])

  @@unique([studentId, examId])
  @@index([examId, schoolId])
}

model SaaSLead {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  centerName  String?
  status      String   @default("Yangi") // Yangi, Bog'lanildi, Sotildi, Rad etildi
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  sellerId    Int?
  seller      User?    @relation("SellerLeads", fields: [sellerId], references: [id])
}

model ApplyToken {
  id        String   @id @default(uuid())
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
