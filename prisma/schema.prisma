// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id         Int       @id @default(autoincrement())
  name       String
  phone      String
  birthDate  String
  address    String
  location   String?
  status     String    @default("Faol")
  joinedDate String
  balance    Float     @default(0)
  photo      String?
  comment    String?
  rating     Float?
  
  // Relations
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  groups     Group[]   @relation("StudentGroups")
  payments   Payment[]
  attendances Attendance[]
  scores      Score[]
}

model Teacher {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  salary          Float
  sharePercentage Float
  lessonFee       Float     @default(0)
  birthDate       String
  hiredDate       String
  photo           String?
  status          String    @default("Faol")

  schoolId        Int
  school          School    @relation(fields: [schoolId], references: [id])
  groups          Group[]
}

model Group {
  id         Int       @id @default(autoincrement())
  name       String
  teacherId  Int
  teacher    Teacher   @relation(fields: [teacherId], references: [id])
  courseId   Int
  course     Course    @relation(fields: [courseId], references: [id])
  schedule   String
  days       String
  room       Int?
  roomRel    Room?     @relation(fields: [room], references: [id])
  
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  students   Student[] @relation("StudentGroups")
  attendances Attendance[]
  scores      Score[]
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  course    String
  source    String
  status    String   @default("Yangi")
  createdAt DateTime @default(now())

  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Float
  type        String
  date        String
  description String

  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
}

model Course {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])
  groups   Group[]
}

model Room {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int

  schoolId Int
  school   School  @relation(fields: [schoolId], references: [id])
  groups   Group[]
}

model School {
  id      Int    @id @default(autoincrement())
  name    String
  address String?

  students Student[]
  teachers Teacher[]
  groups   Group[]
  leads    Lead[]
  payments Payment[]
  courses  Course[]
  rooms    Room[]
  users    User[]
  settings Setting[]
  attendances Attendance[]
  scores      Score[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Score {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  value     Float
  comment   String?
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Setting {
  id               Int      @id @default(autoincrement())
  schoolId         Int      @unique
  school           School   @relation(fields: [schoolId], references: [id])
  orgName          String   @default("SARIOSIYO")
  logo             String?
  adminPhone       String?
  address          String?
  telegram         String?
  instagram        String?
  workingHours     String?
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Hashed
  name      String
  phone     String?
  role      UserRole @default(RECEPTIONIST)
  createdAt DateTime @default(now())

  schoolId  Int?
  school    School?  @relation(fields: [schoolId], references: [id])
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  RECEPTIONIST
}
