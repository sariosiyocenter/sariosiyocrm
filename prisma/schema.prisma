// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id         Int       @id @default(autoincrement())
  name       String
  phone      String
  birthDate  String
  address    String
  location   String?
  status     String    @default("Faol")
  joinedDate String
  balance    Float     @default(0)
  photo      String?
  rating     Float?
  telegramId String?   @unique
  fatherName  String?
  fatherPhone String?
  motherName  String?
  motherPhone String?
  
  // New fields for reports
  statusChangedAt DateTime? @default(now())
  leaveReason     String?

  // Transport Relation
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])
  
  // Student's actual school (maktab)
  studentSchool String?

  // Relations
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  groups     Group[]   @relation("StudentGroups")
  payments   Payment[]
  attendances Attendance[]
  scores      Score[]
  deliveryLogs DeliveryLog[]
}

model Transport {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Avtobus #1"
  model       String?  // e.g., "Mercedes Sprinter"
  number      String?  // Plate number
  capacity    Int
  driverName  String?
  driverPhone String?
  status      String   @default("Faol") // Faol, Ta'mirda, Arxiv
  
  driverId    Int?     @unique
  driver      User?    @relation("DriverTransport", fields: [driverId], references: [id])
  
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  students    Student[]
  deliveryLogs DeliveryLog[]
  routes      Route[]
}

model DeliveryLog {
  id          Int      @id @default(autoincrement())
  transportId Int
  transport   Transport @relation(fields: [transportId], references: [id])
  studentId   Int
  student     Student   @relation(fields: [studentId], references: [id])
  date        String
  status      String    // Olib ketildi, Uyiga yetkazildi, Kelmadi
  
  schoolId    Int
  school      School    @relation(fields: [schoolId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  category    String   // Ish haqi, Ijara, Kommunal, Marketing, Boshqa
  date        String
  description String?
  
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
}

model Teacher {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  salary          Float
  sharePercentage Float
  lessonFee       Float     @default(0)
  salaryType      String    @default("FIXED") // FIXED, KPI, FIXED_KPI
  birthDate       String
  hiredDate       String
  photo           String?
  status          String    @default("Faol")
  telegramId      String?   @unique

  schoolId        Int
  school          School    @relation(fields: [schoolId], references: [id])
  groups          Group[]
  teacherAttendances TeacherAttendance[]
}

model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Group {
  id         Int       @id @default(autoincrement())
  name       String
  teacherId  Int
  teacher    Teacher   @relation(fields: [teacherId], references: [id])
  courseId   Int
  course     Course    @relation(fields: [courseId], references: [id])
  schedule   String
  days       String
  room       Int?
  roomRel    Room?     @relation(fields: [room], references: [id])
  
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  students   Student[] @relation("StudentGroups")
  attendances Attendance[]
  scores      Score[]
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  course    String
  source    String
  status    String   @default("Yangi")
  createdAt DateTime @default(now())

  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Float
  type        String
  date        String
  description String

  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
}

model Course {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])
  groups   Group[]
}

model Room {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int

  schoolId Int
  school   School  @relation(fields: [schoolId], references: [id])
  groups   Group[]
}

model School {
  id      Int    @id @default(autoincrement())
  name    String
  address String?

  students Student[]
  teachers Teacher[]
  groups   Group[]
  leads    Lead[]
  payments Payment[]
  courses  Course[]
  rooms    Room[]
  users    User[]
  settings Setting[]
  attendances Attendance[]
  scores      Score[]
  teacherAttendances TeacherAttendance[]
  expenses    Expense[]
  transports  Transport[]
  deliveryLogs DeliveryLog[]
  routes      Route[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Score {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  value     Float
  comment   String?
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Setting {
  id               Int      @id @default(autoincrement())
  schoolId         Int      @unique
  school           School   @relation(fields: [schoolId], references: [id])
  orgName          String   @default("SARIOSIYO")
  logo             String?
  adminPhone       String?
  address          String?
  telegram         String?
  instagram        String?
  workingHours     String?
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Hashed
  name      String
  phone     String?
  role      UserRole @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  telegramId String?   @unique

  schoolId  Int?
  school    School?  @relation(fields: [schoolId], references: [id])
  
  driverTransport Transport? @relation("DriverTransport")
  driverRoutes    Route[]    @relation("DriverRoutes")
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  RECEPTIONIST
  DRIVER
}

model Route {
  id          Int      @id @default(autoincrement())
  name        String
  startTime   String?   // e.g., "08:00"
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])
  driverId    Int?
  driver      User?    @relation("DriverRoutes", fields: [driverId], references: [id])
  days        String   // TOQ, JUFT, HAR_KUNI
  studentIds  Int[]    // Ordered students
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
