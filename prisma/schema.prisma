// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Student {
  id         Int       @id @default(autoincrement())
  name       String
  phone      String
  birthDate  String
  address    String
  location   String?
  status     String    @default("Faol")
  joinedDate String
  balance    Float     @default(0)
  photo      String?
  rating     Float?
  telegramId String?   @unique
  fatherName  String?
  fatherPhone String?
  motherName  String?
  motherPhone String?

  // New fields for reports
  statusChangedAt DateTime? @default(now())
  leaveReason     String?

  // Transport Relation
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])

  // Student's actual school (maktab)
  studentSchool String?

  // Relations
  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  groups     Group[]   @relation("StudentGroups")
  payments   Payment[]
  attendances Attendance[]
  scores      Score[]
  deliveryLogs DeliveryLog[]
  examResults ExamResult[]
}

model Transport {
  id          Int      @id @default(autoincrement())
  name        String   // e.g., "Avtobus #1"
  model       String?  // e.g., "Mercedes Sprinter"
  number      String?  // Plate number
  capacity    Int
  driverName  String?
  driverPhone String?
  status      String   @default("Faol") // Faol, Ta'mirda, Arxiv
  
  driverId    Int?     @unique
  driver      User?    @relation("DriverTransport", fields: [driverId], references: [id])
  
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  students    Student[]
  deliveryLogs DeliveryLog[]
  routes      Route[]
}

model DeliveryLog {
  id          Int      @id @default(autoincrement())
  transportId Int
  transport   Transport @relation(fields: [transportId], references: [id])
  studentId   Int
  student     Student   @relation(fields: [studentId], references: [id])
  date        String
  status      String    // Olib ketildi, Uyiga yetkazildi, Kelmadi
  
  schoolId    Int
  school      School    @relation(fields: [schoolId], references: [id])
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  category    String   // Ish haqi, Ijara, Kommunal, Marketing, Boshqa
  date        String
  description String?
  
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
}

model Teacher {
  id              Int       @id @default(autoincrement())
  name            String
  phone           String
  salary          Float
  sharePercentage Float
  lessonFee       Float     @default(0)
  salaryType      String    @default("FIXED") // FIXED, KPI, FIXED_KPI
  birthDate       String
  hiredDate       String
  photo           String?
  status          String    @default("Faol")
  telegramId      String?   @unique

  schoolId        Int
  school          School    @relation(fields: [schoolId], references: [id])
  groups          Group[]
  teacherAttendances TeacherAttendance[]
}

model TeacherAttendance {
  id        Int      @id @default(autoincrement())
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Group {
  id         Int       @id @default(autoincrement())
  name       String
  teacherId  Int
  teacher    Teacher   @relation(fields: [teacherId], references: [id])
  courseId   Int
  course     Course    @relation(fields: [courseId], references: [id])
  schedule   String
  days       String
  room       Int?
  roomRel    Room?     @relation(fields: [room], references: [id])

  schoolId   Int
  school     School    @relation(fields: [schoolId], references: [id])
  students   Student[] @relation("StudentGroups")
  attendances Attendance[]
  scores      Score[]
  examAssignments ExamAssignment[]
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  course    String
  source    String
  status    String   @default("Yangi")
  createdAt DateTime @default(now())

  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Payment {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  amount      Float
  type        String
  date        String
  description String

  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
}

model Course {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])
  groups   Group[]
}

model Room {
  id       Int    @id @default(autoincrement())
  name     String
  capacity Int

  schoolId Int
  school   School  @relation(fields: [schoolId], references: [id])
  groups   Group[]
}

model Organization {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  schools   School[]
}

model School {
  id      Int    @id @default(autoincrement())
  name    String
  address String?

  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  students Student[]
  teachers Teacher[]
  groups   Group[]
  leads    Lead[]
  payments Payment[]
  courses  Course[]
  rooms    Room[]
  users    User[]
  settings Setting[]
  attendances Attendance[]
  scores      Score[]
  teacherAttendances TeacherAttendance[]
  expenses    Expense[]
  transports  Transport[]
  deliveryLogs DeliveryLog[]
  routes      Route[]
  smsLogs     SmsLog[]
  questions   Question[]
  exams       Exam[]
  examResults ExamResult[]
  examAssignments ExamAssignment[]
}

model SmsLog {
  id        Int      @id @default(autoincrement())
  toPhone   String
  toName    String?
  message   String
  status    String   @default("PENDING") // SENT, FAILED, PENDING
  type      String   // ATTENDANCE, PAYMENT, PAYMENT_CONFIRM, SCORE, BIRTHDAY
  studentId Int?
  eskizId   String?
  errorMsg  String?
  sentAt    DateTime @default(now())

  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  status    String   // Keldi, Kelmapdi, Sababli
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Score {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  date      String
  value     Float
  comment   String?
  
  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])
}

model Setting {
  id               Int      @id @default(autoincrement())
  schoolId         Int      @unique
  school           School   @relation(fields: [schoolId], references: [id])
  orgName          String   @default("SARIOSIYO")
  logo             String?
  adminPhone       String?
  address          String?
  telegram         String?
  instagram        String?
  workingHours     String?
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // Hashed
  name      String
  phone     String?
  role      UserRole @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  telegramId String?   @unique

  schoolId  Int?
  school    School?  @relation(fields: [schoolId], references: [id])
  
  driverTransport Transport? @relation("DriverTransport")
  driverRoutes    Route[]    @relation("DriverRoutes")
}

enum UserRole {
  ADMIN
  MANAGER
  TEACHER
  RECEPTIONIST
  DRIVER
}

model Route {
  id          Int      @id @default(autoincrement())
  name        String
  startTime   String?   // e.g., "08:00"
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])
  driverId    Int?
  driver      User?    @relation("DriverRoutes", fields: [driverId], references: [id])
  days        String   // TOQ, JUFT, HAR_KUNI
  studentIds  Int[]    // Ordered students
  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id            Int      @id @default(autoincrement())
  text          String
  imageUrl      String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   // 'A' | 'B' | 'C' | 'D'
  difficulty    Int      @default(1)
  subject       String
  topic         String

  schoolId      Int
  school        School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, subject, topic])
}

model Exam {
  id             Int      @id @default(autoincrement())
  name           String
  date           String
  duration       Int
  status         String   @default("Yaqinlashmoqda")
  blocks         Json     // ExamBlock[] — always read as whole, no per-field queries needed
  totalQuestions Int      @default(0)
  maxScore       Float    @default(0)
  variants       Json?    // Variant[] — generated and stored here
  createdAt      DateTime @default(now())

  schoolId       Int
  school         School   @relation(fields: [schoolId], references: [id])
  results        ExamResult[]
  assignments    ExamAssignment[]

  @@index([schoolId])
}

model ExamAssignment {
  id       Int   @id @default(autoincrement())
  examId   Int
  exam     Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  groupId  Int
  group    Group @relation(fields: [groupId], references: [id])
  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])

  @@unique([examId, groupId])
}

model ExamResult {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  examId      Int
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  variantCode String?
  answers     Json?    // Record<number, 'A'|'B'|'C'|'D'|null>
  score       Float    @default(0)
  percentage  Float    @default(0)
  blockScores Json?    // {subject: string, earned: number, max: number}[]
  scannedAt   DateTime @default(now())

  schoolId    Int
  school      School   @relation(fields: [schoolId], references: [id])

  @@unique([studentId, examId])
  @@index([examId, schoolId])
}
